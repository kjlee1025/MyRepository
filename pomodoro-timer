<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>뽀모도로 타이머</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --focus-bg: #0f0e17;
    --focus-accent: #ff6b35;
    --focus-glow: rgba(255, 107, 53, 0.35);
    --break-bg: #0a1628;
    --break-accent: #4ecdc4;
    --break-glow: rgba(78, 205, 196, 0.35);
    --text-primary: #fffffe;
    --text-muted: rgba(255,255,255,0.45);
    --card-bg: rgba(255,255,255,0.04);
    --border: rgba(255,255,255,0.08);
    --accent: var(--focus-accent);
    --glow: var(--focus-glow);
    --bg: var(--focus-bg);
    --transition: 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: background var(--transition);
    overflow: hidden;
    position: relative;
  }

  /* Atmospheric background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, var(--glow), transparent 70%);
    transition: background var(--transition);
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 80%, var(--glow) 0%, transparent 40%),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.02) 0%, transparent 40%);
    transition: background var(--transition);
    pointer-events: none;
    z-index: 0;
  }

  /* Grain texture */
  .grain {
    position: fixed;
    inset: -50%;
    width: 200%;
    height: 200%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
    z-index: 1;
  }

  .container {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 2rem;
    width: 100%;
    max-width: 480px;
  }

  /* Header */
  .header {
    text-align: center;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.1s forwards;
  }

  .header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .header h1 em {
    font-style: italic;
    color: var(--accent);
    transition: color var(--transition);
  }

  /* Mode tabs */
  .mode-tabs {
    display: flex;
    gap: 0.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.25rem;
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }

  .tab {
    padding: 0.5rem 1.5rem;
    border-radius: 100px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .tab.active {
    background: var(--accent);
    color: var(--bg);
    font-weight: 500;
    box-shadow: 0 0 20px var(--glow);
  }

  .tab:not(.active):hover {
    color: var(--text-primary);
  }

  /* Timer ring */
  .timer-wrap {
    position: relative;
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.3s forwards;
  }

  .ring-svg {
    width: clamp(240px, 60vw, 300px);
    height: clamp(240px, 60vw, 300px);
    transform: rotate(-90deg);
  }

  .ring-track {
    fill: none;
    stroke: var(--border);
    stroke-width: 3;
  }

  .ring-progress {
    fill: none;
    stroke: var(--accent);
    stroke-width: 3;
    stroke-linecap: round;
    transition: stroke-dashoffset 1s linear, stroke var(--transition), filter 0.3s ease;
    filter: drop-shadow(0 0 8px var(--accent));
  }

  .timer-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }

  .timer-display {
    font-size: clamp(3.5rem, 12vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s ease;
  }

  .timer-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    transition: color var(--transition);
    font-weight: 500;
  }

  /* Session dots */
  .sessions {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.2);
    transition: all 0.4s ease;
  }

  .dot.done {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 8px var(--glow);
  }

  .dot.current {
    border-color: var(--accent);
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  /* Controls */
  .controls {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.5s forwards;
  }

  .btn {
    border: none;
    cursor: pointer;
    font-family: 'DM Mono', monospace;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .btn:active::after { opacity: 0.1; }

  .btn-primary {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 0 var(--glow);
    transition: all 0.3s ease, background var(--transition), box-shadow var(--transition);
  }

  .btn-primary:hover {
    transform: scale(1.06);
    box-shadow: 0 0 30px var(--glow);
  }

  .btn-primary.playing {
    box-shadow: 0 0 0 8px rgba(255,107,53,0.1), 0 0 40px var(--glow);
    animation: ring-pulse 2s ease-in-out infinite;
  }

  @keyframes ring-pulse {
    0%, 100% { box-shadow: 0 0 0 8px rgba(255,107,53,0.1), 0 0 40px var(--glow); }
    50% { box-shadow: 0 0 0 16px rgba(255,107,53,0.05), 0 0 60px var(--glow); }
  }

  .btn-secondary {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.08);
    color: var(--text-primary);
    border-color: rgba(255,255,255,0.2);
    transform: scale(1.05);
  }

  /* Stats bar */
  .stats {
    margin-top: 3.5rem;
    display: flex;
    gap: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }

  .stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    background: var(--border);
    align-self: stretch;
  }

  /* Notification */
  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--card-bg);
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    padding: 0.75rem 1.5rem;
    border-radius: 100px;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--text-primary);
    z-index: 100;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    white-space: nowrap;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
  }

  /* Break mode */
  body.break-mode {
    --accent: var(--break-accent);
    --glow: var(--break-glow);
    --bg: var(--break-bg);
  }

  body.break-mode .btn-primary.playing {
    animation: ring-pulse-break 2s ease-in-out infinite;
  }

  @keyframes ring-pulse-break {
    0%, 100% { box-shadow: 0 0 0 8px rgba(78,205,196,0.1), 0 0 40px var(--glow); }
    50% { box-shadow: 0 0 0 16px rgba(78,205,196,0.05), 0 0 60px var(--glow); }
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Ticking effect */
  .timer-display.tick {
    animation: tick-anim 0.1s ease;
  }

  @keyframes tick-anim {
    0% { transform: scale(1); }
    50% { transform: scale(0.98); }
    100% { transform: scale(1); }
  }

  /* Completed flash */
  @keyframes complete-flash {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .completing .timer-display {
    animation: complete-flash 0.3s ease 3;
  }
</style>
</head>
<body>
<div class="grain"></div>

<div class="container">
  <div class="header">
    <h1>뽀모<em>도로</em></h1>
  </div>

  <div class="mode-tabs">
    <button class="tab active" id="tab-focus" onclick="setMode('focus')">집중</button>
    <button class="tab" id="tab-break" onclick="setMode('break')">휴식</button>
  </div>

  <div class="timer-wrap">
    <svg class="ring-svg" viewBox="0 0 300 300">
      <circle class="ring-track" cx="150" cy="150" r="136"/>
      <circle class="ring-progress" id="ring" cx="150" cy="150" r="136"
              stroke-dasharray="854.5"
              stroke-dashoffset="0"/>
    </svg>
    <div class="timer-center">
      <div class="timer-display" id="display">25:00</div>
      <div class="timer-label" id="mode-label">집중</div>
    </div>
  </div>

  <div class="sessions" id="sessions"></div>

  <div class="controls">
    <button class="btn btn-secondary" id="btn-reset" onclick="resetTimer()" title="초기화">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
      </svg>
    </button>

    <button class="btn btn-primary" id="btn-play" onclick="toggleTimer()">
      <svg id="icon-play" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <polygon points="5,3 19,12 5,21"/>
      </svg>
      <svg id="icon-pause" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="display:none">
        <rect x="6" y="4" width="4" height="16" rx="1"/>
        <rect x="14" y="4" width="4" height="16" rx="1"/>
      </svg>
    </button>

    <button class="btn btn-secondary" id="btn-skip" onclick="skipTimer()" title="건너뛰기">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="5,4 15,12 5,20"/>
        <line x1="19" y1="5" x2="19" y2="19"/>
      </svg>
    </button>
  </div>

  <div class="stats">
    <div class="stat">
      <div class="stat-value" id="stat-sessions">0</div>
      <div class="stat-label">완료 세션</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-value" id="stat-focus">0</div>
      <div class="stat-label">집중 분</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-value" id="stat-breaks">0</div>
      <div class="stat-label">휴식 횟수</div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const MODES = {
    focus: { duration: 25 * 60, label: '집중', title: '집중 시간' },
    break: { duration: 5 * 60,  label: '휴식', title: '휴식 시간' }
  };

  const TOTAL_DOTS = 4;
  const CIRCUMFERENCE = 2 * Math.PI * 136; // ≈ 854.5

  let mode       = 'focus';
  let timeLeft   = MODES.focus.duration;
  let isRunning  = false;
  let interval   = null;
  let sessionsDone = 0;
  let breaksDone   = 0;
  let focusMinutes = 0;

  // Build session dots
  const sessionsEl = document.getElementById('sessions');
  for (let i = 0; i < TOTAL_DOTS; i++) {
    const d = document.createElement('div');
    d.className = 'dot';
    d.id = `dot-${i}`;
    sessionsEl.appendChild(d);
  }

  function updateDots() {
    for (let i = 0; i < TOTAL_DOTS; i++) {
      const d = document.getElementById(`dot-${i}`);
      d.className = 'dot';
      if (i < sessionsDone % TOTAL_DOTS) d.classList.add('done');
      else if (i === sessionsDone % TOTAL_DOTS && mode === 'focus') d.classList.add('current');
    }
  }

  function updateDisplay() {
    const m = String(Math.floor(timeLeft / 60)).padStart(2, '0');
    const s = String(timeLeft % 60).padStart(2, '0');
    document.getElementById('display').textContent = `${m}:${s}`;

    const total = MODES[mode].duration;
    const progress = timeLeft / total;
    const offset = CIRCUMFERENCE * (1 - progress);
    document.getElementById('ring').style.strokeDashoffset = offset;

    document.title = `${m}:${s} — 뽀모도로`;
  }

  function updateStats() {
    document.getElementById('stat-sessions').textContent = sessionsDone;
    document.getElementById('stat-focus').textContent = focusMinutes;
    document.getElementById('stat-breaks').textContent = breaksDone;
  }

  function setMode(newMode, auto = false) {
    if (isRunning) pauseTimer();
    mode = newMode;
    timeLeft = MODES[mode].duration;

    document.getElementById('tab-focus').classList.toggle('active', mode === 'focus');
    document.getElementById('tab-break').classList.toggle('active', mode === 'break');
    document.getElementById('mode-label').textContent = MODES[mode].label;
    document.body.classList.toggle('break-mode', mode === 'break');

    updateDisplay();
    updateDots();

    if (auto) startTimer();
  }

  // AudioContext 재사용 (메모리 낭비 방지)
  let audioCtx = null;
  function getAudioContext() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }

  function playSound() {
    try {
      const ctx = getAudioContext();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(660, ctx.currentTime);
      gain.gain.setValueAtTime(0.3, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.4);
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start();
      osc.stop(ctx.currentTime + 0.4);
    } catch (e) { console.log('오디오 재생 실패:', e); }
  }

  function startTimer() {
    if (isRunning) return;
    isRunning = true;
    document.getElementById('btn-play').classList.add('playing');
    document.getElementById('icon-play').style.display  = 'none';
    document.getElementById('icon-pause').style.display = '';

    interval = setInterval(() => {
      timeLeft--;

      // 디스플레이 먼저 갱신 후 애니메이션 (00:00 표시 보장)
      updateDisplay();

      const disp = document.getElementById('display');
      disp.classList.remove('tick');
      void disp.offsetWidth;
      disp.classList.add('tick');

      if (timeLeft <= 0) {
        clearInterval(interval); // 인터벌 먼저 클리어
        handleComplete();
      }
    }, 1000);
  }

  function pauseTimer() {
    if (!isRunning) return;
    isRunning = false;
    clearInterval(interval);
    document.getElementById('btn-play').classList.remove('playing');
    document.getElementById('icon-play').style.display  = '';
    document.getElementById('icon-pause').style.display = 'none';
  }

  function toggleTimer() {
    isRunning ? pauseTimer() : startTimer();
  }

  function resetTimer() {
    pauseTimer();
    timeLeft = MODES[mode].duration;
    updateDisplay();
  }

  function skipTimer() {
    handleComplete(true);
  }

  function handleComplete(skipped = false) {
    pauseTimer();
    if (!skipped) playSound(); // 건너뛰기가 아닐 때만 알림음

    const container = document.querySelector('.container');
    container.classList.add('completing');
    setTimeout(() => container.classList.remove('completing'), 1000);

    if (mode === 'focus') {
      sessionsDone++;
      if (!skipped) focusMinutes += 25; // skip 시엔 집중 분 미적용
      updateStats();
      showToast('🍅 집중 완료! 잠깐 쉬어가세요.');
      setTimeout(() => setMode('break', !skipped), 1000); // 00:00 확인 후 전환
    } else {
      breaksDone++;
      updateStats();
      showToast('✨ 휴식 끝! 다시 집중해볼까요?');
      setTimeout(() => setMode('focus', !skipped), 1000);
    }
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // Keyboard shortcuts
  document.addEventListener('keydown', e => {
    if (e.code === 'Space') { e.preventDefault(); toggleTimer(); }
    if (e.code === 'KeyR')  resetTimer();
    if (e.code === 'KeyS')  skipTimer();
  });

  // Init
  updateDisplay();
  updateDots();
  updateStats();
</script>
</body>
</html>
